@model IEnumerable<GameStore.Models.Game>
@{
    ViewData["Title"] = "Admin - Games";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🎮 Gerenciar Games</h2>
        <a asp-action="Create" class="btn btn-primary">+ Cadastrar Novo Game</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">Nenhum jogo cadastrado ainda.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>Descrição</th>
                    <th>Preço</th>
                    <th>URL Imagem</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in Model)
                {
                    <tr>
                        <td>@game.Title</td>
                        <td>@game.ShortDescription</td>
                        <td>R$ @game.Price.ToString("N2")</td>
                        <td>@(string.IsNullOrEmpty(game.ImageUrl) ? "Sem imagem" : game.ImageUrl[..Math.Min(30, game.ImageUrl.Length)])</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@game.Id" class="btn btn-sm btn-danger">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>