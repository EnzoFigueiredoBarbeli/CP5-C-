@model IEnumerable<GameStore.Models.Game>
@{
    ViewData["Title"] = "Home";
}

<section class="bg-dark text-white text-center py-5">
    <div class="container">
        <h1 class="display-4">Domine o Jogo</h1>
        <p class="lead">Os lançamentos mais esperados e as melhores ofertas em um só lugar. Upgrade no seu setup começa aqui.</p>
        <a href="#games" class="btn btn-primary btn-lg">Ver Ofertas</a>
    </div>
</section>

<div class="container my-5" id="games">
    <h2 class="text-center mb-4">🎮 Em Destaque</h2>
    <div class="row">
        @foreach (var game in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@(string.IsNullOrEmpty(game.ImageUrl) ? "https://via.placeholder.com/300x200?text=Game+Cover" : game.ImageUrl)" class="card-img-top" alt="@game.Title">
                    <div class="card-body">
                        <h5 class="card-title">@game.Title</h5>
                        <p class="card-text">@game.ShortDescription</p>
                        <p class="fw-bold text-success">R$ @game.Price.ToString("N2")</p>
                        <a href="#" class="btn btn-outline-primary w-100">Comprar</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>